# ─────────────────────────────────────────────────────────────────────────────
# CyberSec AI — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required ──────────────────────────────────────────────────────────────────
# AbuseIPDB API key — needed for IP reputation checks
# Get a free key at: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here

# ── Ollama ────────────────────────────────────────────────────────────────────
# Overridden to http://ollama:11434 automatically when running in Docker
OLLAMA_URL=http://localhost:11434

# LLM model used by the supervisor and agents
SUPERVISOR_MODEL=ministral:8b

# ── Milvus ────────────────────────────────────────────────────────────────────
# Overridden to http://milvus:19530 automatically when running in Docker
MILVUS_URI=http://localhost:19530

# Name of the Milvus collection used for conversation history
CHAT_MEMORY_COLLECTION=chat_memory

# Max characters stored per message (truncated if longer)
CHAT_MEMORY_MAX_TEXT=12000

# ── UI ────────────────────────────────────────────────────────────────────────
# Backend URL used by the Streamlit UI
# Overridden to http://app:8000 automatically when running in Docker
API_URL=http://localhost:8000
