# ─────────────────────────────────────────────────────────────────────────────
# CyberSec AI — Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────


# ── API Keys ──────────────────────────────────────────────────────────────────

# AbuseIPDB — required for IP reputation checks.
# Free key: https://www.abuseipdb.com/register  (1,000 checks/day on free tier)
ABUSEIPDB_API_KEY=your_abuseipdb_api_key_here


# ── Ollama ────────────────────────────────────────────────────────────────────

# Base URL of the Ollama API.
# Docker: overridden automatically to http://ollama:<OLLAMA_PORT>
# Local:  set to http://localhost:11434  (Ollama default)
OLLAMA_URL=http://localhost:11434

# Host port Ollama is exposed on (Docker only).
# The container always listens on 11434 internally.
OLLAMA_PORT=11434

# LLM model used by the supervisor node.
# Must be pulled with ollama pull <model> before first run.
SUPERVISOR_MODEL=ministral:8b

# LLM model used by the three specialist agents (rag / threat / audit).
# Can be the same as SUPERVISOR_MODEL or a lighter model.
AGENT_MODEL=ministral:8b

# Embedding model used for RAG vector search.
# Must be pulled with ollama pull <model> before first run.
EMBED_MODEL=nomic-embed-text

# LLM inference parameters (shared across all agents).
SUPERVISOR_TEMPERATURE=0
SUPERVISOR_CTX=4096
AGENT_TEMPERATURE=0.1
AGENT_CTX=4096


# ── Milvus ────────────────────────────────────────────────────────────────────

# Full URI for the Milvus gRPC endpoint.
# Docker: overridden automatically to http://milvus:<MILVUS_PORT>
# Local:  http://localhost:19530
MILVUS_URI=http://localhost:19530

# Host port Milvus gRPC is exposed on (Docker only).
MILVUS_PORT=19530

# Host port for Milvus health / metrics endpoint.
MILVUS_METRICS_PORT=9091

# Name of the Milvus collection holding the RAG knowledge base.
COLLECTION_NAME=cybersec_kb

# Name of the Milvus collection holding conversation history.
CHAT_MEMORY_COLLECTION=chat_memory

# Maximum characters stored per message (longer messages are truncated).
CHAT_MEMORY_MAX_TEXT=12000

# Number of recent conversation turns injected before each LLM call.
HISTORY_LIMIT=6


# ── MinIO (Milvus object storage) ─────────────────────────────────────────────

# Change these before deploying to a non-local environment.
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin

# Host ports MinIO is exposed on (Docker only).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001


# ── FastAPI backend ───────────────────────────────────────────────────────────

# Host port the FastAPI backend is exposed on (Docker only).
API_PORT=8000

# Allowed CORS origins for the API (comma-separated, or * for all).
# Example: CORS_ORIGINS=https://myapp.example.com,https://admin.example.com
CORS_ORIGINS=*


# ── Streamlit UI ──────────────────────────────────────────────────────────────

# Host port the Streamlit UI is exposed on (Docker only).
UI_PORT=8501

# Backend URL the Streamlit UI calls.
# Docker: overridden automatically to http://app:<API_PORT>
# Local:  http://localhost:8000
API_URL=http://localhost:8000


# ── RAG tuning ────────────────────────────────────────────────────────────────

# Number of knowledge-base chunks returned per search query.
RAG_TOP_K=5

# Minimum cosine similarity to include a chunk (0.0–1.0).
# Raise to get stricter / fewer results; lower for broader recall.
RAG_SCORE_THRESHOLD=0.60


# ── Threat analysis tuning ────────────────────────────────────────────────────

# AbuseIPDB confidence score (0–100) above which an IP is flagged malicious.
IP_MALICIOUS_THRESHOLD=25


# ── HTTP timeouts ─────────────────────────────────────────────────────────────

# Timeout (seconds) for general HTTP calls (CVE, IP, HIBP APIs).
HTTP_TIMEOUT=15

# Timeout (seconds) for Ollama embedding calls (can be slow on first run).
EMBED_TIMEOUT=60


# ── External API base URLs (advanced / proxy override) ────────────────────────

# Override these to point at internal proxies or mirrors.
# NVD_BASE_URL=https://services.nvd.nist.gov/rest/json/cves/2.0
# ABUSEIPDB_BASE_URL=https://api.abuseipdb.com/api/v2
# HIBP_BASE_URL=https://api.pwnedpasswords.com/range
